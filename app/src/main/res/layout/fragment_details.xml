<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.details.DetailsFragment">

    <!-- Coffee Image -->
    <ImageView
        android:id="@+id/imgCoffee"
        android:layout_width="0dp"
        android:layout_height="350dp"
        android:src="@drawable/cappuccino_1"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:contentDescription="coffee image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_circle_overlay"
        android:src="@drawable/ic_back"
        android:padding="10dp"
        android:elevation="8dp"
        android:contentDescription="back"
        app:layout_constraintTop_toTopOf="@id/imgCoffee"
        app:layout_constraintStart_toStartOf="parent"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:tint="@android:color/white" />

<!--fav icon-->
    <ImageButton
        android:id="@+id/btnFav"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_circle_overlay"
        android:src="@drawable/favorite_border_ic"
        android:padding="10dp"
        android:elevation="8dp"
        android:contentDescription="favorite"
        app:layout_constraintTop_toTopOf="@id/imgCoffee"
        app:layout_constraintEnd_toEndOf="parent"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:tint="@android:color/white" />

    <!-- Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDetails"
        style="@style/TopRoundedCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-30dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/imgCoffee"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/scrollDetails"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <!-- CONTENT -->
            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Title + Rating -->
                <LinearLayout
                    android:id="@+id/layoutTitleRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:id="@+id/layoutTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Espresso Coffee"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="with Chocolate"
                            android:textSize="14sp"
                            android:textColor="@color/dark_gray"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.5"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />
                </LinearLayout>

                <!-- Separator Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/muted_gray"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="18dp"/>

                <!-- Description Title -->
                <TextView
                    android:id="@+id/tvDescriptionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                     />

                <!-- Description Text -->
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A Espresso is an approximately 150 ml (5 oz) beverage, with 25 ml of espresso coffee and 85 ml of fresh milk the foam on top."
                    android:textSize="14sp"
                    android:textColor="@color/dark_gray"
                    android:lineSpacingExtra="4dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:layout_marginTop="8dp" />

                <!-- Read More -->
                <TextView
                    android:id="@+id/tvReadMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read more →"
                    android:textSize="13sp"
                    android:textColor="@color/primary_color"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tvQuantityLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Quantity"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <!-- Counter -->
                    <LinearLayout
                        android:id="@+id/layoutQuantity"
                        android:layout_width="120dp"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_counter_card"
                        android:paddingHorizontal="12dp">

                        <!-- minus -->
                        <TextView
                            android:id="@+id/btnMinus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="−"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:gravity="center"/>

                        <!-- quantity -->
                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:gravity="center"/>

                        <!-- plus -->
                        <TextView
                            android:id="@+id/btnPlus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="+"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>


                <!-- Spacer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="20dp"/>

                <!-- Price + Button -->
                <LinearLayout
                    android:id="@+id/layoutPriceBuy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:id="@+id/layoutPrice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPriceLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Price"
                            android:textSize="14sp"
                            android:textColor="@color/gray" />

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="450 EGP"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBuyNow"
                        android:layout_width="160dp"
                        android:layout_height="52dp"
                        android:text="Buy Now"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/primary_color"
                        app:cornerRadius="22dp"
                        android:stateListAnimator="@null"
                        android:elevation="6dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
